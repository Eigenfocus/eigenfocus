<% if @todo.destroyed? %>
  <%= turbo_stream.remove dom_id(@todo) %>
<% else %>
  <%= turbo_stream.replace dom_id(@todo) do %>
    <%= render partial: "issues/todos/todo", locals: { todo: @todo } %>
  <% end %>

  <% if @new_todo %>
    <%= turbo_stream.append dom_id(@todo.todo_list, :todos) do %>
      <%= turbo_frame_tag dom_id(@new_todo) do %>
        <%= render partial: "issues/todos/form", locals: { todo: @new_todo, adding: true } %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
