<%= turbo_frame_tag dom_id(todo_list) do %>
  <div class="cpy-todo-list group/list rounded-box border border-base-300 p-3"
    data-controller="issue--todos">
    <div class="flex items-center justify-between gap-2">
      <div class="flex items-center gap-2 grow">
        <%= link_to todo_list.title,
          edit_issue_todo_list_path(todo_list.issue, todo_list),
          class: "cpy-todo-list-title font-medium text-base-content cursor-pointer",
          data: { turbo_frame: dom_id(todo_list), "issue--todos-target": "title" } %>
        <span class="text-xs opacity-60" data-issue--todos-target="count"></span>
      </div>

      <%= button_to issue_todo_list_path(todo_list.issue, todo_list),
        method: :delete,
        class: "cpy-delete-todo-list btn btn-ghost btn-xs btn-error opacity-0 group-hover/list:opacity-100",
        form: { data: { turbo_confirm: t("todo_lists.confirm_delete") } } do %>
        <%= icon_for(:remove) %>
      <% end %>
    </div>

    <div id="<%= dom_id(todo_list, :todos) %>" class="mt-2 flex flex-col gap-1">
      <%= render partial: "issues/todos/todo", collection: todo_list.todos.order(:created_at), as: :todo %>
    </div>

    <%= button_to t("todo_lists.add_item"), issue_todo_list_todos_path(todo_list.issue, todo_list),
      method: :post,
      class: "btn btn-ghost btn-xs self-start mt-2 opacity-70" %>
  </div>
<% end %>
